# Example environment variables for local development and CI
# COPY this file to `.env` for local development (the `.env` file is gitignored)
# Replace the placeholder values with your local credentials. Do NOT commit
# real credentials into the repository.

# JDBC URL for MySQL. If you run MySQL locally, use localhost and default port 3306.
# If you use a managed DB in CI/production, set the full connection string there.
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/mvc_rest?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true

# Database user and password (placeholders)
SPRING_DATASOURCE_USERNAME=YOUR_DB_USER
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD

# Optional: Spring profile
# SPRING_PROFILES_ACTIVE=dev

